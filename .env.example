# ──────────────────────────────────────────────────────────
# PR Review System — Local Development (v2)
# Copy this file to .env and fill in GITHUB_TOKEN at minimum.
# ──────────────────────────────────────────────────────────

# ── LLM provider ───────────────────────────────────────────
# Options:
#   ollama        — Ollama running locally (default, see docker-compose.yml)
#   docker-model  — Docker Desktop Model Runner (requires Docker Desktop 4.40+)
#   bedrock       — AWS Bedrock (production, needs real AWS creds + Bedrock access)
LLM_PROVIDER=ollama

# Model name used by the selected provider:
#   ollama:       gemma4:4b | gemma4:12b | gemma2:9b | llama3.2 | ...
#   docker-model: ai/gemma4 | ai/llama3.2 | ...
#   bedrock:      (set BEDROCK_MODEL_ID below instead)
LLM_MODEL=gemma4:4b

# Ollama endpoint (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Docker Model Runner endpoint (used when LLM_PROVIDER=docker-model)
# Docker Desktop exposes this automatically — no extra container needed.
DOCKER_MODEL_ENDPOINT=http://localhost:12434/engines/llama.cpp/v1

# AWS Bedrock model ID (used when LLM_PROVIDER=bedrock)
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── AWS / DynamoDB ─────────────────────────────────────────
# Use fake credentials for local DynamoDB — boto3 still requires them.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# Point to local DynamoDB container (leave unset to use real AWS DynamoDB).
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE=pr-review-local-memory

# ── GitHub ─────────────────────────────────────────────────
# PAT with repo + pull_requests:write scope.
# Required for --pr-url reviews and posting comments.
# Leave empty to review local diff files only.
GITHUB_TOKEN=

# ── Webhook server (api.py) ────────────────────────────────
# Set to "skip" to disable HMAC validation (fine for local dev).
WEBHOOK_SECRET=skip

# API server port (api.py)
API_PORT=8080

# ── Environment flag ───────────────────────────────────────
ENV=local
