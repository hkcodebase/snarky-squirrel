# ────────────────────────────────────────────────────────────────────────────
# Local dev with AWS Bedrock + AWS DynamoDB  (SSO / named profile)
#
# Steps:
#   1. aws sso login --profile <your-profile>
#   2. cd infra/dev && terraform init && terraform apply
#   3. terraform output -raw env_block > ../../.env
#   4. Add GITHUB_TOKEN to .env
#   5. python api.py              (no Docker required)
# ────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=bedrock

# Model must have access granted in AWS Bedrock console → Model access.
# Match the value of var.bedrock_model_id from your terraform.tfvars.
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── AWS credentials (SSO profile) ────────────────────────────────────────────
# boto3 resolves credentials from the named profile (~/.aws/config).
# Run:  aws sso login --profile <your-profile>  before starting the server.
AWS_REGION=us-east-1
AWS_PROFILE=default

# ── DynamoDB (real AWS) ───────────────────────────────────────────────────────
# Fill from: terraform output dynamodb_table_name  (or terraform output -raw env_block)
DYNAMODB_TABLE=pr-review-memory-dev

# Leave DYNAMODB_ENDPOINT empty to use real AWS DynamoDB (not localhost).
DYNAMODB_ENDPOINT=

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here

# Set to a real secret if you're wiring up a GitHub webhook.
# "skip" disables HMAC validation for local testing.
WEBHOOK_SECRET=skip
